					SetAnchor(v,true)	
					AddMesh(v)	
					SetMesh(v,111891702759441)	
					SetTexture(v,id)	
					MeshResize(v,Vector3.new(8000,8000,8000))	
				end	
			end	
		end	
	
		Sky("84437077150729")	
	end)	
